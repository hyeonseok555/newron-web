{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: debug server",
      "type": "node-terminal",
      "request": "launch",
      "command": "export PATH=\"/home/hs-2/.local/share/pnpm/bin:$PATH\" && pnpm dev:debug",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Next.js: debug client",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}"
    }
  ],
  "compounds": [
    {
      "name": "Next.js: full stack",
      "configurations": [
        "Next.js: debug server",
        "Next.js: debug client"
      ],
      "stopAll": true
    }
  ]
}
